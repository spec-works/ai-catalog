{
  "description": "Identifier reuse across a parent catalog and a bundle entry — cross-bundle identifier reuse indicates the same logical artifact per BU-4",
  "spec_section": "§ Organizing Catalogs — Bundles (BU-4)",
  "test_ids": ["BN-P04"],
  "input": {
    "specVersion": "1.0",
    "entries": [
      {
        "identifier": "urn:example:mcp:shared-tool",
        "displayName": "Shared Tool (parent reference)",
        "mediaType": "application/mcp-server+json",
        "url": "https://mcp.example.com/shared-tool/manifest.json",
        "version": "1.0.0"
      },
      {
        "identifier": "urn:example:bundles:team-tools",
        "displayName": "Team Tools Bundle",
        "mediaType": "application/ai-catalog+json",
        "inline": {
          "specVersion": "1.0",
          "entries": [
            {
              "identifier": "urn:example:mcp:shared-tool",
              "displayName": "Shared Tool (bundle copy)",
              "mediaType": "application/mcp-server+json",
              "url": "https://mcp.example.com/shared-tool/manifest.json",
              "version": "1.0.0"
            },
            {
              "identifier": "urn:example:mcp:team-only-tool",
              "displayName": "Team-Only Tool",
              "mediaType": "application/mcp-server+json",
              "url": "https://mcp.example.com/team-only/manifest.json"
            }
          ]
        }
      }
    ]
  },
  "expected": {
    "valid": true,
    "entry_count": 2,
    "cross_bundle_identifier_reuse": true,
    "reused_identifier": "urn:example:mcp:shared-tool"
  }
}
