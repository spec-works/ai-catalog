        "url": "https://mcp.example.com/duplicate1/manifest.json"
      },
      {
        "identifier": "urn:example:mcp:duplicate-tool",
        "displayName": "Duplicate Tool (second)",
        "mediaType": "application/mcp-server+json",
        "url": "https://mcp.example.com/duplicate2/manifest.json"
      }
    ]
  },
  "expected_error": "duplicate identifier 'urn:example:mcp:duplicate-tool' without version differentiation"
