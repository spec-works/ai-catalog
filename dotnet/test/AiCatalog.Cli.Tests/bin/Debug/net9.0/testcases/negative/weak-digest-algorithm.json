        "mediaType": "application/a2a-agent-card+json",
        "url": "https://agents.example.com/weak/agent-card.json",
        "trustManifest": {
          "identity": "urn:example:agents:weak-digest",
          "attestations": [
            {
              "type": "SecurityAudit",
              "uri": "https://audits.example.com/report.pdf",
              "mediaType": "application/pdf",
